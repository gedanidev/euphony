# ── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://euphony:euphony@db:5432/euphony

# ── Frontend ─────────────────────────────────────────────────────────────────
# Base URL for API calls from the browser (default: /api — works with Vite proxy or Caddy)
VITE_API_URL=/api

# Vite dev proxy target (used inside Docker only, not exposed to browser)
BACKEND_URL=http://backend:8000

# ── Production ───────────────────────────────────────────────────────────────
# Override the default postgres password in prod
DB_PASSWORD=changeme
