# ── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://euphony:euphony@db:5432/euphony

# ── Frontend ─────────────────────────────────────────────────────────────────
# Base URL for API calls from the browser (default: /api — works with Vite proxy or Caddy)
VITE_API_URL=/api

# Vite dev proxy target (used inside Docker only, not exposed to browser)
BACKEND_URL=http://backend:8000

# ── Production ───────────────────────────────────────────────────────────────
# Override the default postgres password in prod
DB_PASSWORD=changeme

# ── Spotify OAuth ─────────────────────────────────────────────────────────────
# Get from: https://developer.spotify.com → Create App
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# In dev: http://localhost:8000/api/auth/spotify/callback
# In prod: https://tu-dominio.com/api/auth/spotify/callback
SPOTIFY_REDIRECT_URI=http://localhost:8000/api/auth/spotify/callback
FRONTEND_URL=http://localhost:5173
